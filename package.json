{
  "name": "svelte-doodle-icons",
  "version": "1.0.0",
  "description": "466+ hand-drawn doodle style icons for Svelte. Port of doodle-icons with 100 additional healthcare icons.",
  "license": "MIT",
  "type": "module",
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "node generate.mjs && svelte-package -i src/lib -o dist",
    "generate": "node generate.mjs"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "svelte": "^5.0.0",
    "@sveltejs/package": "^2.0.0",
    "typescript": "^5.0.0"
  },
  "keywords": ["svelte", "icons", "doodle", "hand-drawn", "healthcare", "ui"],
  "repository": {
    "type": "git",
    "url": "https://github.com/ajentik/svelte-doodle-icons.git"
  }
}
